meta {
  name: 2FA Challenge
  type: http
  seq: 3
}

post {
  url: {{base_url}}/auth/2fa/challenge
  body: json
  auth: none
}

body:json {
  {
    "pending_token": "{{pending_token}}",
    "totp_code": "123456"
  }
}

script:post-response {
  if (res.status === 200 && res.body.access_token) {
    bru.setEnvVar("access_token", res.body.access_token);
  }
}
